{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop",
  "description": "Desktop-only plugins (dialogs, process restart, updater)",
  "windows": ["main"],
  "platforms": ["linux", "macOS", "windows"],
  "permissions": [
    "dialog:default",
    "dialog:allow-confirm",
    "process:default",
    "process:allow-restart",
    "updater:default"
  ]
}
